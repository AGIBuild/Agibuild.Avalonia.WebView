<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>ShowcaseTodo.Bridge</RootNamespace>
    <BridgeTypeScriptOutputDir>$(MSBuildProjectDirectory)\..\ShowcaseTodo.Web\src\bridge\generated</BridgeTypeScriptOutputDir>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Agibuild.Fulora.Core" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Agibuild.Fulora.Bridge.Generator" OutputItemType="Analyzer" ReferenceOutputAssembly="false" PrivateAssets="all" />
  </ItemGroup>

</Project>
