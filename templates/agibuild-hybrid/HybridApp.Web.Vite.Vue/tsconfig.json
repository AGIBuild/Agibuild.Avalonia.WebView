{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ES2023", "DOM"],
    "types": ["vite/client", "vitest/globals"],
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/**/*.d.ts", "../HybridApp.Bridge/bridge.d.ts"]
}
